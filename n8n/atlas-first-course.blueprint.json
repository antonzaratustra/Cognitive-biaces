{
  "name": "Cognitive Bias Atlas Course Blueprint",
  "version": "0.1.0",
  "description": "Naming, callbacks and data contracts for the n8n workflow that mirrors the previous course bot structure.",
  "telegram": {
    "entrypoints": ["/start", "lead_<uuid>", "lesson_<slug>", "quiz_offer"],
    "lesson_buttons": [
      "lesson:next:<lesson_id>",
      "lesson:atlas:<lesson_slug>",
      "lesson:save:<lesson_id>",
      "lesson:ai:<lesson_id>"
    ],
    "ai_suggestions": [
      "ai:suggest:<lesson_id>:life",
      "ai:suggest:<lesson_id>:spot",
      "ai:suggest:<lesson_id>:practice"
    ]
  },
  "tables": [
    "cb_users",
    "cb_lessons",
    "cb_user_lessons",
    "cb_saved_lessons",
    "cb_ai_threads",
    "cb_ai_messages",
    "cb_ai_usage",
    "cb_products",
    "cb_purchases",
    "cb_entitlements",
    "cb_events"
  ],
  "workflow_blocks": [
    {
      "id": "register_or_restore_user",
      "purpose": "Find user by tg_id, restore lead linkage, and create user row when missing."
    },
    {
      "id": "deliver_lesson_card",
      "purpose": "Send text/image lesson card with 4 fixed inline buttons."
    },
    {
      "id": "handle_save_and_progress",
      "purpose": "Persist save action and move user to the next lesson."
    },
    {
      "id": "handle_ai_prompt",
      "purpose": "Resolve current lesson context, store user input and call OpenRouter."
    },
    {
      "id": "handle_stars_purchase",
      "purpose": "Create invoice, validate pre_checkout_query and grant quiz entitlement after successful_payment."
    }
  ],
  "openrouter": {
    "endpoint": "https://openrouter.ai/api/v1/chat/completions",
    "env_model_key": "OPENROUTER_MODEL",
    "env_api_key": "OPENROUTER_API_KEY",
    "default_payload_shape": {
      "model": "{{ $env.OPENROUTER_MODEL }}",
      "messages": [
        { "role": "system", "content": "{{ lesson.ai_context }}" },
        { "role": "user", "content": "{{ user_question }}" }
      ]
    }
  }
}
